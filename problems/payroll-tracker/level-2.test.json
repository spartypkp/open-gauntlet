{
  "visible": [
    {
      "name": "top_workers returns top N by total time descending",
      "operations": [
        [
          "init"
        ],
        [
          "add_worker",
          "alice",
          "engineer",
          100
        ],
        [
          "add_worker",
          "bob",
          "analyst",
          100
        ],
        [
          "register",
          "alice",
          1
        ],
        [
          "register",
          "alice",
          10
        ],
        [
          "register",
          "bob",
          2
        ],
        [
          "register",
          "bob",
          5
        ],
        [
          "top_workers",
          2
        ]
      ],
      "expected": [
        null,
        true,
        true,
        "registered",
        "registered",
        "registered",
        "registered",
        [
          "alice(9)",
          "bob(3)"
        ]
      ]
    },
    {
