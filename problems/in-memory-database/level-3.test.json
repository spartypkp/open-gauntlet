{
  "visible": [
    {
      "name": "Field expires at timestamp+ttl (exclusive boundary)",
      "operations": [
        [
          "init"
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "val",
          1,
          10
        ],
        [
          "get_at",
          "A",
          "B",
          5
        ],
        [
          "get_at",
          "A",
          "B",
          10
        ],
        [
          "get_at",
          "A",
          "B",
          11
        ]
      ],
      "expected": [
        null,
        null,
        "val",
        "val",
        null
      ]
    },
    {
      "name": "set_at field never expires",
      "operations": [
        [
          "init"
        ],
        [
          "set_at",
          "A",
          "B",
          "val",
          5
        ],
        [
          "get_at",
          "A",
          "B",
          100
        ]
      ],
      "expected": [
        null,
        null,
        "val"
      ]
    }
  ],
  "hidden": [
    {
      "name": "delete_at on expired field returns false",
      "operations": [
        [
          "init"
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "val",
          1,
          5
        ],
        [
          "delete_at",
          "A",
          "B",
          10
        ]
      ],
      "expected": [
        null,
        null,
        false
      ]
    },
    {
      "name": "scan_at excludes expired fields",
      "operations": [
        [
          "init"
        ],
        [
          "set_at",
          "A",
          "B",
          "1",
          1
        ],
        [
          "set_at_with_ttl",
          "A",
          "C",
          "2",
          1,
          5
        ],
        [
          "scan_at",
          "A",
          10
        ]
      ],
      "expected": [
        null,
        null,
        null,
        "B(1)"
      ]
    },
    {
      "name": "Overwrite with set_at makes field permanent",
      "operations": [
        [
          "init"
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "old",
          1,
          5
        ],
        [
          "set_at",
          "A",
          "B",
          "new",
          3
        ],
        [
          "get_at",
          "A",
          "B",
          10
        ],
        [
          "set",
          "Z",
          "f1",
          "v1"
        ],
        [
          "set",
          "Z",
          "f2",
          "v2"
        ],
        [
          "get",
          "Z",
          "f1"
        ],
        [
          "scan",
          "Z"
        ],
        [
          "scan_by_prefix",
          "Z",
          "f1"
        ],
        [
          "delete",
          "Z",
          "f1"
        ],
        [
          "scan",
          "Z"
        ]
      ],
      "expected": [
        null,
        null,
        null,
        "new",
        null,
        null,
        "v1",
        "f1(v1), f2(v2)",
        "f1(v1)",
        true,
        "f2(v2)"
      ]
    },
    {
      "name": "scan_by_prefix_at respects TTL",
      "operations": [
        [
          "init"
        ],
        [
          "set_at",
          "A",
          "BA",
          "1",
          1
        ],
        [
          "set_at_with_ttl",
          "A",
          "BB",
          "2",
          1,
          5
        ],
        [
          "scan_by_prefix_at",
          "A",
          "B",
          10
        ]
      ],
      "expected": [
        null,
        null,
        null,
        "BA(1)"
      ]
    },
    {
      "name": "delete_at on valid field returns true",
      "operations": [
        [
          "init"
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "val",
          1,
          10
        ],
        [
          "delete_at",
          "A",
          "B",
          5
        ],
        [
          "get_at",
          "A",
          "B",
          6
        ]
      ],
      "expected": [
        null,
        null,
        true,
        null
      ]
    },
    {
      "name": "Overwrite expired field creates fresh entry",
      "operations": [
        [
          "init"
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "old",
          1,
          5
        ],
        [
          "set_at_with_ttl",
          "A",
          "B",
          "new",
          10,
          10
        ],
        [
          "get_at",
          "A",
          "B",
          15
        ]
      ],
      "expected": [
        null,
        null,
        null,
        "new"
      ]
    }
  ]
}
