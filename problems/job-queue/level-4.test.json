          "a",
          20
        ],
        [
          "check_timeouts",
          40
        ],
        [
          "get_status",
          "a"
        ]
      ],
      "expected": [
        null,
        true,
        "a",
        true,
        [],
        "running"
      ]
    },
    {
      "name": "Get running jobs with time remaining",
      "operations": [
        ["init"],
        ["enqueue", "a", {}],
