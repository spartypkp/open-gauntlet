{
  "visible": [
    {
      "name": "Visibility timeout returns job to queue",
      "operations": [
        [
          "init"
        ],
        [
          "enqueue",
          "a",
          {}
        ],
        [
          "dequeue",
          30
        ],
        [
          "check_timeouts",
          35
        ],
        [
          "get_status",
          "a"
        ],
        [
          "dequeue"
        ]
      ],
      "expected": [
        null,
        true,
        "a",
        [
          "a"
        ],
        "pending",
        "a"
      ]
    },
    {
      "name": "Extend visibility keeps job running",
      "operations": [
