{
  "visible": [
    {
      "name": "Snapshot speeds up state computation",
      "operations": [
        [
          "init"
        ],
        [
          "append",
          "s1",
          "init",
          {
            "a": 1
          }
        ],
        [
          "append",
          "s1",
          "update",
          {
            "b": 2
          }
        ],
        [
          "create_snapshot",
          "s1"
        ],
        [
          "append",
          "s1",
          "update",
          {
            "c": 3
          }
        ],
        [
          "get_current_state",
          "s1"
        ]
      ],
      "expected": [
        null,
        0,
        1,
        1,
        2,
        {
          "a": 1,
          "b": 2,
          "c": 3
        }
      ]
    },
    {
      "name": "Create snapshot returns version",
      "operations": [
        [
          "init"
        ],
        [
          "append",
          "s1",
          "ev",
          {
            "x": 1
          }
        ],
        [
          "append",
          "s1",
          "ev",
          {
            "y": 2
          }
        ],
        [
          "append",
          "s1",
          "ev",
          {
            "z": 3
          }
        ],
        [
          "create_snapshot",
          "s1"
        ]
      ],
      "expected": [
        null,
        0,
        1,
        2,
        2
      ]
    }
  ],
  "hidden": [
    {
      "name": "Snapshot on non-existent stream",
      "operations": [
        [
          "init"
        ],
        [
          "create_snapshot",
          "ghost"
        ]
      ],
      "expected": [
        null,
        null
      ]
    },
