{
  "visible": [
    {
      "name": "Cross-stream aggregate",
      "operations": [
        [
          "init"
        ],
        [
          "append",
          "s1",
          "ev",
          {
            "a": 1
          }
        ],
        [
          "append",
          "s2",
          "ev",
          {
            "b": 2
          }
        ],
        [
          "create_aggregate",
          "agg",
          [
            "s1",
            "s2"
          ]
        ],
        [
          "get_aggregate",
          "agg"
        ]
      ],
      "expected": [
        null,
        0,
        0,
        true,
        {
          "a": 1,
          "b": 2
        }
      ]
    },
    {
      "name": "Replay events from position",
      "operations": [
        [
          "init"
        ],
        [
          "append",
          "s1",
          "created",
          {
            "id": 1
          }
        ],
        [
          "append",
          "s1",
          "updated",
          {
            "id": 1,
            "name": "test"
          }
        ],
        [
          "append",
          "s1",
          "deleted",
          {
            "id": 1
          }
        ],
        [
          "replay_from",
          "s1",
          1
        ]
      ],
      "expected": [
        null,
        0,
        1,
        2,
        [
          {
            "position": 1,
            "event_type": "updated",
            "data": {
              "id": 1,
              "name": "test"
            }
          },
          {
            "position": 2,
            "event_type": "deleted",
            "data": {
              "id": 1
            }
          }
        ]
      ]
    }
  ],
