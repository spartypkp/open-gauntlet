          "alice",
          "video.mp4"
        ],
        [
          "get_file_size",
          "video.mp4"
        ],
        [
          "get_file_size",
          "video.mp4.compressed"
        ]
      ],
      "expected": [
        null,
        true,
        200,
        600,
        null,
        400
      ]
    },
